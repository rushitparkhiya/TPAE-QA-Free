 *   - Each flow body (navigate, interact, verify — see PITFALLS.md)
 *
 * Run:
 *   WP_TEST_URL=http://localhost:PORT npx playwright test \
 *     tests/playwright/flows/my-comparison.spec.js \
 *     --config=tests/playwright/playwright.config.js \
 *     --project=video
 *
 * Before running: node setup/plugin-setup.js --plugin <slug>
 */
const { test, expect } = require('@playwright/test');
const fs   = require('fs');
const path = require('path');
const { detectErrorPage, slowScroll } = require('../helpers');

const BASE  = process.env.WP_TEST_URL || 'http://localhost:8881';
const ADMIN = `${BASE}/wp-admin`;
const SNAP  = path.join(__dirname, '../../../reports/screenshots/flows-compare');
const DATA  = path.join(__dirname, '../../../reports/compare-data.json');

fs.mkdirSync(SNAP, { recursive: true });

// ── Plugin config ──────────────────────────────────────────────────────────
// Change these to match the plugins you're comparing
const A_SLUG       = 'plugin-a';             // prefix for screenshots: pa-01-discovery.png
const B_SLUG       = 'plugin-b';
const A_ADMIN_PAGE = 'admin.php?page=plugin-a-settings';
const B_ADMIN_PAGE = 'admin.php?page=plugin-b-settings';

const results = {};

function saveData() {
  fs.writeFileSync(DATA, JSON.stringify(results, null, 2));
}

async function snap(page, name) {
  const file = path.join(SNAP, `${name}.png`);
  await page.screenshot({ path: file, fullPage: false });
  return file;
}

// ── Plugin A Flows ─────────────────────────────────────────────────────────

test.describe(`${A_SLUG.toUpperCase()} — UAT Flows`, () => {

  // Flow 1: Discovery
  // UAT question: How many clicks does it take to find this plugin from the dashboard?
  test(`${A_SLUG.toUpperCase()}-1 | Discovery`, async ({ page }) => {
    await page.goto(`${ADMIN}/`);
    await page.waitForLoadState('domcontentloaded');
    await page.waitForTimeout(1500);

    // Check for environment errors before recording anything
    if (await detectErrorPage(page)) {
      console.log(`[SETUP_REQUIRED] ${A_SLUG} — admin dashboard shows error`);
      return;
    }

    await snap(page, `${A_SLUG}-01-dashboard`);

    // TODO: Find your plugin's menu item
    // const menuItem = page.locator('#adminmenu a').filter({ hasText: /your-plugin-name/i });
    // const found = await menuItem.count() > 0;
    // if (found) { await menuItem.hover(); await menuItem.click(); }

    results[A_SLUG] = results[A_SLUG] || {};
    results[A_SLUG].discovery = { /* TODO: clicks, found, label */ };
    saveData();
  });

  // Flow 2: Settings complexity
  // UAT question: How complex is this plugin to configure? Can a non-developer use it?
  test(`${A_SLUG.toUpperCase()}-2 | Settings complexity`, async ({ page }) => {
    await page.goto(`${ADMIN}/${A_ADMIN_PAGE}`);
    await page.waitForLoadState('domcontentloaded');
    await page.waitForTimeout(3000); // wait for JS-heavy admin pages to render

    if (await detectErrorPage(page)) {
      console.log(`[SETUP_REQUIRED] ${A_SLUG} — settings page shows error. Run: node setup/plugin-setup.js --plugin ${A_SLUG}`);
      return;
    }

    await snap(page, `${A_SLUG}-02-settings-top`);
    await slowScroll(page, 5); // show full page in video
    await snap(page, `${A_SLUG}-02b-settings-full`);

    // Count meaningful UI elements (use page.evaluate for dynamic/React pages)
    const uiCounts = await page.evaluate(() => ({
      inputs:   document.querySelectorAll('input:not([type=hidden]):not([type=submit])').length,
      toggles:  document.querySelectorAll('input[type=checkbox], input[type=radio]').length,
      selects:  document.querySelectorAll('select').length,
      sections: document.querySelectorAll('fieldset, .settings-section, .card, [role="region"]').length,
    }));

    results[A_SLUG] = results[A_SLUG] || {};
    results[A_SLUG].settings = uiCounts;
    saveData();
  });

  // Flow 3: Core feature
  // UAT question: Does the main feature work end-to-end for a real user?
  test(`${A_SLUG.toUpperCase()}-3 | Core feature`, async ({ page }) => {
    // TODO: Navigate to where the core feature is used
    // TODO: Simulate real user interaction
    // TODO: Verify the outcome the user would care about
    // See PITFALLS.md for how to write this properly
  });

  // Flow 4: Frontend output
  // UAT question: Does the plugin actually affect what visitors see?
  test(`${A_SLUG.toUpperCase()}-4 | Frontend output`, async ({ page }) => {
    await page.goto(BASE);
    await page.waitForLoadState('domcontentloaded');
    await snap(page, `${A_SLUG}-04-frontend`);

    // TODO: Check for plugin's frontend output
    // Examples: meta tags, schema markup, canonical URLs, widgets
  });

});

