{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--headless --no-sandbox --disable-gpu",
        "formFactor": "desktop",
        "screenEmulation": {
          "mobile": false,
          "width": 1440,
          "height": 900,
          "deviceScaleFactor": 1
        },
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"]
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.75 }],
        "categories:accessibility":   ["error", { "minScore": 0.85 }],
        "categories:best-practices":  ["warn",  { "minScore": 0.80 }],
        "categories:seo":             ["warn",  { "minScore": 0.85 }],

        "first-contentful-paint":     ["warn",  { "maxNumericValue": 2000 }],
        "largest-contentful-paint":   ["warn",  { "maxNumericValue": 3500 }],
        "total-blocking-time":        ["warn",  { "maxNumericValue": 300 }],
        "cumulative-layout-shift":    ["warn",  { "maxNumericValue": 0.1 }],
        "interactive":                ["warn",  { "maxNumericValue": 4000 }],

        "uses-optimized-images":      ["warn", { "logLevel": "warn" }],
        "uses-text-compression":      ["warn", { "logLevel": "warn" }],
        "render-blocking-resources":  ["warn", { "logLevel": "warn" }],

        "color-contrast":             ["error", { "logLevel": "error" }],
        "document-title":             ["error", { "logLevel": "error" }],
        "meta-description":           ["warn",  { "logLevel": "warn" }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "reports/lighthouse"
    }
  }
}
