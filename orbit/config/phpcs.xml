<?xml version="1.0"?>
<ruleset name="Orbit WordPress Coding Standards">
  <description>WordPress plugin coding standards — WordPress + VIP rules</description>

  <!-- Scan PHP files only -->
  <arg name="extensions" value="php"/>

  <!-- Exclude generated/vendor code -->
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/build/*</exclude-pattern>
  <exclude-pattern>*/dist/*</exclude-pattern>
  <exclude-pattern>*/tests/*</exclude-pattern>
  <exclude-pattern>*-min.php</exclude-pattern>

  <!-- WordPress Coding Standards -->
  <rule ref="WordPress">
    <!-- Allow short array syntax [] -->
    <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
    <!-- Allow file-level docblocks to be optional -->
    <exclude name="Squiz.Commenting.FileComment"/>
  </rule>

  <!-- WordPress VIP Go standards -->
  <rule ref="WordPressVIPMinimum">
    <!-- Allow direct DB queries with wpdb->prepare -->
    <exclude name="WordPress.DB.DirectDatabaseQuery.NoCaching"/>
  </rule>

  <!-- PHP compatibility — WP requires PHP 7.4+ -->
  <rule ref="PHPCompatibilityWP">
    <config name="testVersion" value="7.4-"/>
  </rule>

  <!-- Security rules — these are never excluded -->
  <rule ref="WordPress.Security.EscapeOutput"/>
  <rule ref="WordPress.Security.NonceVerification"/>
  <rule ref="WordPress.DB.PreparedSQL"/>
  <rule ref="WordPress.WP.Capabilities"/>

  <!-- Performance rules -->
  <rule ref="WordPress.WP.EnqueuedResourceParameters"/>
  <rule ref="WordPress.DB.SlowDBQuery"/>

  <!-- Strict capability checks -->
  <rule ref="WordPress.WP.Capabilities">
    <properties>
      <property name="custom_capabilities" type="array" value="manage_options,edit_posts"/>
    </properties>
  </rule>

  <!-- Show progress and colors in CLI -->
  <arg value="ps"/>
  <arg name="colors"/>
  <arg name="parallel" value="8"/>
</ruleset>
