# Copy to .env and fill in your values — never commit .env

# ── WordPress site ──────────────────────────────────────────
WP_BASE_URL=http://localhost
WP_TEST_URL=http://localhost        # orbit alias (same value)

# ── Admin credentials ───────────────────────────────────────
WP_ADMIN_USER=admin
WP_ADMIN_PASS=password

# ── Plugin path (for static audits) ────────────────────────
WP_PLUGIN_PATH=/path/to/the-plus-addons-for-elementor-page-builder

# ── Test page slugs ─────────────────────────────────────────
WP_HEADING_PAGE_SLUG=/tpae-test-heading/
WP_ACCORDION_PAGE_SLUG=/tpae-test-accordion/
WP_BLOG_PAGE_SLUG=/tpae-test-blog-listout/
WP_FORM_PAGE_SLUG=/tpae-test-plus-form/
WP_COUNTDOWN_PAGE_SLUG=/tpae-test-countdown/
WP_COUNTER_PAGE_SLUG=/tpae-test-number-counter/
WP_FLIPBOX_PAGE_SLUG=/tpae-test-flip-box/
WP_NAV_PAGE_SLUG=/tpae-test-navigation-menu/
WP_VIDEO_PAGE_SLUG=/tpae-test-video/
WP_TABS_PAGE_SLUG=/tpae-test-tabs-tours/

# ── Widget settings ─────────────────────────────────────────
WP_COUNTER_TARGET=100

# ── Orbit options ───────────────────────────────────────────
# Set to true in CI to use WP Playground instead of a real site
USE_PLAYGROUND=false
PLAYWRIGHT_WORKERS=1
